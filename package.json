{
  "name": "glass-marble-chess",
  "version": "1.0.0",
  "description": "An Electron 3D chess experience with marble, glass, and production-grade move validation.",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1 --port 4173\" \"wait-on tcp:4173 && VITE_DEV_SERVER_URL=http://127.0.0.1:4173 electron .\"",
    "start": "npm run dev",
    "prepare:stockfish": "node scripts/fetch-stockfish.mjs",
    "build": "vite build",
    "package:mac:dir": "npm run build && electron-builder --mac dir",
    "package:mac": "npm run build && electron-builder --mac zip dmg",
    "test:packaged-smoke": "npm run package:mac:dir && node tests/packaged-smoke.mjs",
    "test:unit": "node --test tests/unit/*.test.mjs tests/integration/*.test.mjs",
    "test:e2e": "npm run build && node tests/electron.spec.mjs",
    "check": "npm run test:unit && npm run test:e2e"
  },
  "keywords": [
    "electron",
    "threejs",
    "chess"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@fontsource/cormorant-garamond": "^5.2.11",
    "@fontsource/public-sans": "^5.2.7",
    "chess.js": "^1.4.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "playwright": "^1.58.2",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.nizda.glass-marble-chess",
    "asar": true,
    "files": [
      "dist/**",
      "electron/**",
      "src/**",
      "index.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/stockfish",
        "to": "stockfish"
      }
    ],
    "mac": {
      "category": "public.app-category.games",
      "target": [
        "zip",
        "dmg"
      ]
    }
  }
}
